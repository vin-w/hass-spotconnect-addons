{
  "name": "SpotConnect",
  "version": "0.20.1",
  "slug": "spotconnect",
  "description": "Expose AirPlay and UPnP devices as Spotify Connect speakers",
  "arch": ["armv7", "armhf", "aarch64", "amd64", "i386"],
  "network_mode": "host",
  "map": ["config:rw"],
  "options": {
    "mode": "raop",
    "puid": 1000,
    "pgid": 1000,
    "vorbis_bitrate": 320,
    "store_cred_xml": false,
    "log_level_raop": "info"
  },
  "schema": {
    "mode": "list(raop|upnp)",
    "puid": "int",
    "pgid": "int",
    "vorbis_bitrate": "list(96|160|320)",
    "store_cred_xml": "bool",
    "log_level_raop": "list(error|warn|info|debug|sdebug)"
  }
}
